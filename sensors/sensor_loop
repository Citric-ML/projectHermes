import numpy as np

def compute_scale(depth_map, sonar_depth, pixel=(133, 133),#change this later depending on how the system is constructed
                  min_scale=0.5, max_scale=2.5,
                  min_camera_depth=1e-6):
    """
    Computes a global depth scaling factor using sonar reference.

    Parameters:
        depth_map (np.ndarray): 2D array from MiDaS (relative depth).
        sonar_depth (float): Measured sonar depth in meters.
        pixel (tuple): (row, col) index aligned with sonar direction.
        min_scale (float): Minimum allowed scale factor.
        max_scale (float): Maximum allowed scale factor.
        min_camera_depth (float): Threshold to prevent division by zero.

    Returns:
        float or None: Valid scale factor, or None if invalid.
    """

    # 1. Validate sonar reading
    if sonar_depth is None:
        return None

    if sonar_depth <= 0:
        return None

    # 2. Validate pixel bounds
    h, w = depth_map.shape
    r, c = pixel

    if not (0 <= r < h and 0 <= c < w):
        return None

    # 3. Extract camera depth at sonar-aligned pixel
    camera_depth = depth_map[r, c]

    # 4. Validate camera depth
    if not np.isfinite(camera_depth):
        return None

    if camera_depth <= min_camera_depth:
        return None

    # 5. Compute scale
    scale = sonar_depth / camera_depth

    # 6. Clamp / reject extreme scale
    if not (min_scale <= scale <= max_scale):
        return None

    return scale





